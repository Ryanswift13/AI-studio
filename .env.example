# Claudio 配置 —— 复制本文件为 .env 并按需填写。
# 任何一项留空，对应集成会自动降级为本地模拟，核心闭环仍可跑通。
# 注意：本文件是模板，不要在此填写真实密钥（会被提交进仓库）。密钥只写进 .env。

# ── DeepSeek（电台大脑，直连 API）──────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# 单轮编排超时（毫秒）
DEEPSEEK_TIMEOUT_MS=90000

# ── Claude Code CLI（可选备用大脑，默认未启用）─────────
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_MS=90000

# ── NeteaseCloudMusicApi（音乐）────────────────────────
NCM_BASE_URL=http://localhost:3000
# 音质档位（VIP 建议 exhigh；黑胶可试 lossless）
NCM_LEVEL=exhigh
# 若扫码后仍只有 30s 试听，可从浏览器复制 Cookie 粘贴到此（需含 MUSIC_U）
NCM_COOKIE=
# 1 = Claudio 启动时自动拉起本地 NeteaseCloudMusicApi 服务；0 = 自行启动
NCM_AUTOSTART=1

# ── TTS 语音合成 ───────────────────────────────────────
# 引擎优先级：Fish（配了 key）→ Edge TTS（免费）→ 纯文本。
# 默认即用免费的 Edge TTS，下面 Fish 几项留空即可。
#
# Edge TTS（微软免费神经语音，无需 key）。常用中文声音：
#   zh-CN-XiaoxiaoNeural 晓晓·女   zh-CN-XiaoyiNeural 晓伊·女
#   zh-CN-YunxiNeural 云希·男      zh-CN-YunjianNeural 云健·男·浑厚
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
#
# Fish Audio（音色更佳，按量付费）：https://fish.audio → 控制台创建 API key
FISH_API_KEY=
# 声音模型 reference id（在 fish.audio 选定声音后获取）
FISH_VOICE_ID=
FISH_BASE_URL=https://api.fish.audio

# ── 天气 ───────────────────────────────────────────────
# open-meteo 免 key。填城市经纬度即可。默认：上海。
WEATHER_LAT=31.23
WEATHER_LON=121.47
WEATHER_CITY=Shanghai

# ── 日历（ICS 订阅）───────────────────────────────────
# 填日历的 ICS 订阅链接，留空则不注入日程。
# iCloud：共享日历后会得到一条 webcal:// 链接，直接粘进来即可。
# Google：日历设置 →「日历的秘密地址(iCal 格式)」。
# 也可改填本地 .ics 文件路径（CALENDAR_ICS_FILE）。
CALENDAR_ICS_URL=
CALENDAR_ICS_FILE=

# ── UPnP / Naim 客厅功放 ──────────────────────────────
# 1 = 启用 SSDP 发现并推送；0 = 关闭
UPNP_ENABLED=1
# 指定设备 location（留空则自动 SSDP 发现）
UPNP_DEVICE_LOCATION=

# ── 应用 ───────────────────────────────────────────────
# 启动后是否打开 DevTools
DEVTOOLS=0
