# Claudio 配置 —— 复制本文件为 .env 并按需填写。
# 任何一项留空，对应集成会自动降级为本地模拟，核心闭环仍可跑通。

# ── DeepSeek（电台大脑，直连 API）──────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-e71a429de2de4bb9b8cf6fb2f364c76c
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_MS=90000

# ── NeteaseCloudMusicApi（音乐）────────────────────────
# 需在本地另起 NeteaseCloudMusicApi 服务，默认端口 3000。
NCM_BASE_URL=http://localhost:3000
# 音质档位（VIP 建议 exhigh；黑胶可试 lossless）
NCM_LEVEL=exhigh
# 若扫码后仍只有 30s 试听，可从浏览器复制 Cookie 粘贴到此（需含 MUSIC_U）
NCM_COOKIE=

# ── Fish Audio（TTS 语音合成）──────────────────────────
FISH_API_KEY=
# 声音模型 reference id（在 fish.audio 控制台获取）
FISH_VOICE_ID=
FISH_BASE_URL=https://api.fish.audio

# ── 天气 ───────────────────────────────────────────────
# open-meteo 免 key。填城市经纬度即可。默认：上海。
WEATHER_LAT=31.23
WEATHER_LON=121.47
WEATHER_CITY=Shanghai

# ── 飞书（日程/日历）──────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 日历 id，留空则取主日历
FEISHU_CALENDAR_ID=

# ── UPnP / Naim 客厅功放 ──────────────────────────────
# 1 = 启用 SSDP 发现并推送；0 = 关闭
UPNP_ENABLED=1
# 指定设备 location（留空则自动 SSDP 发现）
UPNP_DEVICE_LOCATION=

# ── 应用 ───────────────────────────────────────────────
# 启动后是否打开 DevTools
DEVTOOLS=0
